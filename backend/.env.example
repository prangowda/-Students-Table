# Backend Environment Variables
# Copy this file to .env and fill in your PostgreSQL connection string

# PostgreSQL connection string
# Examples:
#   Neon:     postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/studentsdb?sslmode=require
#   Local:    postgresql://postgres:password@localhost:5432/studentsdb
#   Railway:  from the Railway dashboard > your DB > Connect tab
DATABASE_URL="postgresql://username:password@localhost:5432/studentsdb"
